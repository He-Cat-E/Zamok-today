# HTTP port for the API (default: 4000)
PORT=4000

# MongoDB connection string
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/zamok_today
# Atlas: if mongodb+srv:// fails with querySrv ECONNREFUSED in Node (but Compass works), use the
# "standard connection string" from Atlas (mongodb://shard0...:27017,...) — it skips SRV DNS.
#
# Optional: DNS servers for mongodb+srv SRV lookups only (comma-separated). Default: 8.8.8.8,1.1.1.1
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional token for Travelpayouts whereami API (recommended)
# TRAVELPAYOUTS_API_TOKEN=your_token_here

# Allowed origins for CORS (comma-separated for multiple apps)
CLIENT_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# Super admin (auto-created on first API start if no admin exists)
ADMIN_EMAIL=admin@zamok.today
ADMIN_PASSWORD=Admin123!@#
# ADMIN_JWT_EXPIRES_IN=7d

# Auth (JWT in httpOnly cookie)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# SMTP (password reset, welcome, security emails)
# Required for production password reset delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
# Optional: override From header (defaults to "Zamok Today" <SMTP_USER>)
# MAIL_FROM="Zamok Today <noreply@yourdomain.com>"
MAIL_SITE_NAME=Zamok Today
# Set MAIL_DISABLED=true to turn off sending without removing credentials
# MAIL_DISABLED=false

# Google Cloud Vision (profile ID scan) — path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# NetGSM SMS (phone sign-in / sign-up OTP)
# NETGSM_USERCODE=8503055987      # Abone numarası (same as NETGSM_USER)
# NETGSM_PASSWORD=your_api_subuser_password
#   ^ API alt kullanıcı şifresi — NOT your main Netgsm panel login password.
#     Create: Abonelik İşlemleri → Alt Kullanıcı → API Kullanıcısı → enable SMS + API access.
# NETGSM_HEADER=MEPFUTURE         # Onaylı gönderici adı (Ayarlar → Mesaj Başlıklarım)
# NETGSM_APPKEY=                  # Optional: from Ayarlar → API İşlemleri (if your account uses appkey)
# NETGSM_REST_USERNAME=           # Optional: only if REST Basic user differs from usercode
# NETGSM_DISABLED=false
# EXPOSE_PHONE_OTP=true           # Return OTP in API JSON when SMS cannot be sent (dev)
# NETGSM_DEV_FALLBACK=true        # In dev: allow phone OTP flow when NetGSM returns code 30
# Test: npm run netgsm:test
# Check: GET http://localhost:4000/api/health/netgsm (shows publicIp to whitelist)
