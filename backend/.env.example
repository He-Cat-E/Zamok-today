# HTTP port for the API (default: 4000)
PORT=4000

# MongoDB connection string
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/zamok_today
# Atlas: if mongodb+srv:// fails with querySrv ECONNREFUSED in Node (but Compass works), use the
# "standard connection string" from Atlas (mongodb://shard0...:27017,...) — it skips SRV DNS.
#
# Optional: DNS servers for mongodb+srv SRV lookups only (comma-separated). Default: 8.8.8.8,1.1.1.1
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional token for Travelpayouts whereami API (recommended)
# TRAVELPAYOUTS_API_TOKEN=your_token_here

# Allowed origin for CORS (Next.js dev server by default)
CLIENT_ORIGIN=http://localhost:3000

# Auth (JWT in httpOnly cookie)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# SMTP (password reset, welcome, security emails)
# Required for production password reset delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
# Optional: override From header (defaults to "Zamok Today" <SMTP_USER>)
# MAIL_FROM="Zamok Today <noreply@yourdomain.com>"
MAIL_SITE_NAME=Zamok Today
# Set MAIL_DISABLED=true to turn off sending without removing credentials
# MAIL_DISABLED=false
